# Copiar este archivo como ".env" y completar con tus datos
# IMPORTANTE: .env NO se sube a GitHub (está en .gitignore)

SECRET_KEY=
#!!! rellenais con lo que querais

MYSQL_HOST=localhost
MYSQL_USER=root

MYSQL_PASSWORD=
#rellenais con la que tengais; MYSQL_PASSWORD= vacío significa que tu 
# MySQL NO tiene contraseña (común en instalaciones locales de desarrollo)

MYSQL_DB=cediza